            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5007/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5007",
